# Copy this file to .env.docker on the server, then replace the values.
WEB_PORT=80

# MySQL container settings. Keep MYSQL_DATABASE as bishe_backend because init.sql uses it.
MYSQL_ROOT_PASSWORD=change_this_root_password
MYSQL_USER=bishe_user
MYSQL_PASSWORD=change_this_app_password

# JWT signing secret used by the Spring Boot backend.
JWT_SECRET=change_this_to_a_long_random_secret

# OpenAI-compatible LLM settings.
# Example for Alibaba Cloud DashScope compatible mode:
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_MODEL=qwen-plus
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.example.com
LLM_MODEL=your_model_name
LLM_TIMEOUT_SECONDS=30
